# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Docs: https://learn.microsoft.com/en-us/azure/ai-services/openai/
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o          # your deployment name
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ── Google Vertex AI (Gemini + Claude) ────────────────────────────────────────
# Docs: https://cloud.google.com/vertex-ai/docs/start/client-libraries
# Docs (multi-region EU): https://cloud.google.com/vertex-ai/docs/general/locations#europe
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=europe-west4      # EU single-region; use 'eu' for EU multi-region
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Vertex Gemini model
VERTEX_GEMINI_MODEL=gemini-2.5-flash-001

# Vertex Claude model
# Docs: https://cloud.google.com/vertex-ai/generative-ai/docs/partner-models/use-claude
VERTEX_CLAUDE_MODEL=claude-sonnet-4-5@20251001

# ── AWS Bedrock (Anthropic Claude) ────────────────────────────────────────────
# Docs: https://docs.aws.amazon.com/bedrock/latest/userguide/what-is-bedrock.html
# EU regions: eu-west-1 (Dublin), eu-central-1 (Frankfurt), eu-north-1 (Stockholm)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
BEDROCK_CLAUDE_MODEL=anthropic.claude-sonnet-4-5-20251001-v1:0

# ── Self-hosted OpenAI-compatible endpoint (vLLM / Ollama proxy / LocalAI) ───
# Example vLLM server:
#   vllm serve Qwen/Qwen3-32B --host 0.0.0.0 --port 8000 --served-model-name qwen3-32b
# Example endpoint: http://localhost:8000/v1
SELF_HOSTED_BASE_URL=http://localhost:8000/v1
SELF_HOSTED_API_KEY=local-dev-key
SELF_HOSTED_MODEL=qwen3-32b
